# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build/*
!/build/icon.svg
/release
/desktop/stage

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# debug output
.debug/
dev.log
dev.err.log
.playwright-mcp/

# cloakbrowser persistent profile
.cloak-profile/

# TikTok session cookies — sensitive, never commit
.tiktok-session.json

# Persistent scrape cache (SQLite)
.cache/

# claude-code per-user local settings
.claude/settings.local.json

# misc
lol.txt
mitm_mcp_traffic.db

# typescript
*.tsbuildinfo
next-env.d.ts
